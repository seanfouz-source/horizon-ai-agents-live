OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
METRICOOL_API_TOKEN=
MANYCHAT_API_TOKEN=

# Optional shared secret for Manychat, Zapier, and Metricool webhook calls.
# Send it as the x-horizon-secret header or as ?secret=...
WEBHOOK_SHARED_SECRET=

# Optional eBay API sync. CSV import works without these.
EBAY_ACCESS_TOKEN=
EBAY_MARKETPLACE_ID=EBAY_US

# Default public eBay store-page source. Used until official eBay API access is ready.
EBAY_STORE_URL=https://www.ebay.com/str/exactspec
EBAY_STORE_MAX_PAGES=3
SYNC_STORE_PAGE_ON_STARTUP=true

# Local database path. Defaults to data/horizon_agents.db.
DATABASE_PATH=data/horizon_agents.db

# Daily report email. Use REPORT_EMAIL_PROVIDER=smtp or gmail.
REPORT_BASE_URL=https://horizon-ai-agents.onrender.com
REPORT_EMAIL_TO=sean.fouz@gmail.com,horizonwirelesstx@gmail.com
REPORT_EMAIL_PROVIDER=smtp
REPORT_EMAIL_FROM=
REPORT_EMAIL_FROM_NAME=Horizon AI Agents
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
GMAIL_SENDER=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
