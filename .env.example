OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
METRICOOL_API_TOKEN=
MANYCHAT_API_TOKEN=

# Optional shared secret for Manychat, Zapier, and Metricool webhook calls.
# Send it as the x-horizon-secret header or as ?secret=...
WEBHOOK_SHARED_SECRET=

# Optional eBay API sync. CSV import works without these.
EBAY_ACCESS_TOKEN=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REFRESH_TOKEN=
EBAY_OAUTH_SCOPES=https://api.ebay.com/oauth/api_scope
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_SELLER_USERNAME=exactspec-electronics
EBAY_BROWSE_SEARCH_QUERY=
EBAY_EXPAND_ITEM_GROUPS=true
EBAY_TRADING_COMPATIBILITY_LEVEL=1455
SYNC_EBAY_API_ON_STARTUP=true

# Default public eBay store-page source. Used until official eBay API access is ready.
EBAY_STORE_URL=https://www.ebay.com/str/exactspec
EBAY_STORE_SALE_MEDIA_URL=https://raw.githubusercontent.com/seanfouz-source/horizon-ai-agents-live/main/assets/horizon-summer-sale-square.jpg
EBAY_STORE_MAX_PAGES=3
SYNC_STORE_PAGE_ON_STARTUP=true
SYNC_INVENTORY_BEFORE_SOCIAL_POSTS=true

# Walmart Marketplace direct seller API integration.
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=
WALMART_API_BASE_URL=https://marketplace.walmartapis.com
WALMART_MARKET=us
WALMART_SERVICE_NAME=Walmart Marketplace
WALMART_CHANNEL_TYPE=
# Optional fallback only when every imported package uses the same verified weight.
WALMART_DEFAULT_SHIPPING_WEIGHT_LBS=

# Metricool scheduling guardrails.
METRICOOL_DAILY_POST_LIMIT=2
METRICOOL_MORNING_POST_TIME=09:00
METRICOOL_EVENING_POST_TIME=18:00
METRICOOL_REPOST_COOLDOWN_DAYS=14

# Local database path. Defaults to data/horizon_agents.db.
DATABASE_PATH=data/horizon_agents.db

# Daily report email. Use REPORT_EMAIL_PROVIDER=smtp or gmail.
REPORT_BASE_URL=https://horizon-ai-agents.onrender.com
REPORT_EMAIL_TO=sean.fouz@gmail.com,horizonwirelesstx@gmail.com
REPORT_EMAIL_PROVIDER=smtp
REPORT_EMAIL_FROM=
REPORT_EMAIL_FROM_NAME=Horizon AI Agents
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
GMAIL_SENDER=
GMAIL_CLIENT_CREDENTIALS_FILE=
GMAIL_REFRESH_TOKEN_CURRENT=
